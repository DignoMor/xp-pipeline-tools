{
  "script_generators": {
    "slurm": {
      "variables": {
        "interpreter": {
          "default": "/bin/bash",
          "flag": "-S",
          "help": "Interpreter to run the script"
        },
        "job_name": {
          "default": "the_one_job",
          "flag": "-N",
          "help": "name of the job[the_one_job]"
        },
        "num_nodes": {
          "default": "1",
          "flag": "--nodes",
          "help": "number of nodes for the program to ran on"
        },
        "num_cores": {
          "default": "1",
          "flag": "--ppn",
          "help": "number of cores for the program to ran on"
        },
        "memory": {
          "default": "16G",
          "flag": "--mem",
          "help": "Memory needed for the program."
        },
        "gpu": {
          "default": "none",
          "flag": "--gpu",
          "help": "GPU gres for the job (e.g. gpu:1)."
        },
        "time": {
          "default": 12,
          "flag": "-t",
          "help": "estimated walltime hours"
        },
        "queue": {
          "default": "CPU",
          "flag": "-q",
          "help": "queue or cluster partition for the job"
        },
        "conda_environment": {
          "default": "buddingScripts",
          "flag": "--conda",
          "help": "Conda environment to activate"
        }
      },
      "setting_str": {
        "#!<setting>": "interpreter",
        "#SBATCH --job-name=<setting>": "job_name",
        "#SBATCH -N <setting>": "num_nodes",
        "#SBATCH --cpus-per-task=<setting>": "num_cores",
        "#SBATCH --mem=<setting>": "memory",
        "#SBATCH --gres=<setting>": "gpu",
        "#SBATCH --time=<setting>:00:00": "time",
        "#SBATCH -p <setting>": "queue",
        "#SBATCH -o <setting>.out": "job_name",
        "#SBATCH -e <setting>.err": "job_name",
        "conda activate <setting>": "conda_environment"
      }
    },
    "bash": {
      "variables": {
        "job_name": {
          "default": "the_one_job",
          "flag": "-N",
          "help": "name of the job"
        }
      },
      "setting_str": {
        "# Job Name: <setting>": "job_name"
      }
    },
    "plainPy": {
      "variables": {
        "job_name": {
          "default": "the_one_job",
          "flag": "-N",
          "help": "name of the job"
        }
      },
      "setting_str": {
        "# Job Name: <setting>": "job_name"
      }
    }
  },
  "templates": {
    "#header1#": "header1",
    "#header2#": "header2",
    "#header3#": "header3",
    "#header4#": "header4",
    "#header5#": "header5"
  },
  "suffix": {
    "slurm": ".slurm",
    "bash": ".sh",
    "plainPy": ".py"
  }
}
